---
import ArrowLink from "../ArrowLink.astro";
import { projects } from "../../data/projects";
---

<section id="projects" class="pb-18">
  <h2 class="text-text-bright mb-8 font-mono text-2xl tracking-[-0.02em]">
    projects
  </h2>

  <div
    class="grid grid-cols-1 gap-14 sm:grid-cols-[repeat(auto-fill,minmax(22rem,1fr))]"
  >
    {
      projects.map((project) => (
        <div class="max-w-xs">
          <a
            href={project.links[0].url}
            target="_blank"
            rel="noopener noreferrer"
            class="project-image-link mx-auto mb-4 block"
          >
            <img
              src={project.image}
              alt={project.name}
              class="max-h-100 max-w-full"
              loading="lazy"
            />
          </a>

          <h3 class="text-text-bright mb-1 font-mono text-lg">
            {project.name.toLowerCase()}
          </h3>

          <p class="text-muted mb-2 text-sm">{project.summary.toLowerCase()}</p>

          <p class="text-muted-dark mb-3 font-mono text-xs">
            {project.techStack.toLowerCase()}
          </p>

          <div class="flex flex-wrap gap-4">
            {project.links.map((link) => (
              <ArrowLink href={link.url} label={link.label} external />
            ))}
          </div>
        </div>
      ))
    }
  </div>
</section>
